# ============================================================================
# Talk2Database — environment configuration
#
# Copy this file to `.env` and fill in the values:
#     cp .env.example .env
#
# All services (panel, cron, both Postgres containers) read from this file.
# NEVER commit your real `.env` — it is gitignored.
# ============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL MAJOR version for the user-data DB, the cron sync tooling, and the
# panel's restore client. It MUST be >= the major version of your source
# database (the backup you upload, or the REMOTE_DB_DSN server). Use only the
# major version number (e.g. 14, 15, 16, 17) — NOT a Docker image tag like
# "14.1-alpine". Changing this after first run requires recreating the userdata
# volume (it is a rebuildable copy).
POSTGRES_VERSION=16

# ---------------------------------------------------------------------------
# Data loading mode  (pick exactly ONE)
#   manual    -> admins upload .sql / pg_dump backups through the panel
#   scheduled -> a cron job full-refreshes from REMOTE_DB_DSN every N hours
# The unused path is disabled at runtime.
# ---------------------------------------------------------------------------
IMPORT_MODE=manual

# ---------------------------------------------------------------------------
# AI provider  (converts natural language -> a single read-only SELECT)
#   AI_PROVIDER : anthropic | openai
#   AI_MODEL    : e.g. claude-opus-4-8  (Anthropic)  |  gpt-4o (OpenAI)
# Only the database SCHEMA is ever sent to the provider — never row data.
# ---------------------------------------------------------------------------
AI_PROVIDER=anthropic
AI_API_KEY=replace-me
AI_MODEL=claude-opus-4-8

# Schema cost controls (see docs/architecture.md "Schema caching").
# If the serialized schema exceeds SCHEMA_MAX_TOKENS, only the tables most
# relevant to the question (plus their foreign-key neighbours) are sent.
SCHEMA_MAX_TOKENS=6000
# Optional comma-separated allowlist of tables to expose to the AI (empty = all).
SCHEMA_TABLES=
# Postgres schemas to introspect (comma-separated).
SCHEMA_INCLUDE_SCHEMAS=public

# ---------------------------------------------------------------------------
# Authentication
# Generate a strong secret, e.g.:  openssl rand -hex 32
# ---------------------------------------------------------------------------
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRE_MINUTES=60
# Base URL of the panel, used to build invite acceptance links.
APP_BASE_URL=http://localhost:8000
# Extra browser origins allowed to call the API (comma-separated). Leave empty
# when the SPA is served by the panel itself (the default single-container setup).
CORS_ORIGINS=

# ---------------------------------------------------------------------------
# Query execution guard rails (applied to every AI-generated query)
# ---------------------------------------------------------------------------
QUERY_MAX_ROWS=1000
QUERY_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Panel database (postgres-panel) — stores users, history, import runs, schema snapshots
# ---------------------------------------------------------------------------
PANEL_DB_HOST=postgres-panel
PANEL_DB_PORT=5432
PANEL_DB_NAME=panel
PANEL_DB_USER=panel
PANEL_DB_PASSWORD=replace-me-panel

# ---------------------------------------------------------------------------
# User-data database (postgres-userdata) — the queryable copy of the user's data
#   ADMIN_*    : full-privilege role used ONLY for restores/sync (never for queries)
#   READONLY_* : SELECT-only role used for ALL AI query execution + introspection
# ---------------------------------------------------------------------------
USERDATA_DB_HOST=postgres-userdata
USERDATA_DB_PORT=5432
USERDATA_DB_NAME=userdata
USERDATA_DB_ADMIN_USER=postgres
USERDATA_DB_ADMIN_PASSWORD=replace-me-userdata-admin
USERDATA_READONLY_USER=t2db_readonly
USERDATA_READONLY_PASSWORD=replace-me-readonly

# ---------------------------------------------------------------------------
# Scheduled sync (only used when IMPORT_MODE=scheduled)
#   REMOTE_DB_DSN : source Postgres to copy FROM, e.g.
#                   postgresql://user:pass@host:5432/dbname
# The source major version must be <= the userdata Postgres major version.
# ---------------------------------------------------------------------------
SYNC_INTERVAL_HOURS=6
SYNC_RUN_ON_STARTUP=true
REMOTE_DB_DSN=postgresql://user:password@remote-host:5432/source_db
