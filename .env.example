# ============================================================================
# Talk2Database — environment configuration
#
# Copy this file to `.env` and fill in the values:
#     cp .env.example .env
#
# The panel and its metadata database read from this file.
# Data sources (PostgreSQL, MySQL, MariaDB, ...) are NOT configured here — each
# user registers connections to their own databases at runtime via the UI.
# NEVER commit your real `.env` — it is gitignored.
# ============================================================================

# ---------------------------------------------------------------------------
# AI provider  (converts natural language -> a single read-only SELECT)
#   AI_PROVIDER : anthropic | openai
#   AI_MODEL    : e.g. claude-opus-4-8  (Anthropic)  |  gpt-4o (OpenAI)
# Only the database SCHEMA is sent to the provider — never row data — unless
# you explicitly enable ANSWER_SUMMARY_ENABLED below.
# ---------------------------------------------------------------------------
AI_PROVIDER=anthropic
AI_API_KEY=replace-me
AI_MODEL=claude-opus-4-8

# When the generated SQL references tables/columns that do not exist in the
# schema, the model is re-prompted with a correction up to ASK_MAX_RETRIES
# times before giving up. ASK_VERIFY_IDENTIFIERS=false disables the check.
ASK_MAX_RETRIES=2
ASK_VERIFY_IDENTIFIERS=true

# Natural-language answer summaries ("Your total income for 2025 was ...").
# OFF by default because they send a CAPPED SAMPLE of query result rows to the
# AI provider — a deliberate exception to schema-only grounding. See
# docs/security.md before enabling.
ANSWER_SUMMARY_ENABLED=false
ANSWER_SUMMARY_MAX_ROWS=20
ANSWER_SUMMARY_MAX_COLUMNS=15
ANSWER_SUMMARY_MAX_CELL_CHARS=200

# How many AI-generated example questions to cache per schema snapshot.
SUGGESTED_QUESTIONS_COUNT=5

# Schema cost controls (see docs/architecture.md "Schema caching").
# If the serialized schema exceeds SCHEMA_MAX_TOKENS, only the tables most
# relevant to the question (plus their foreign-key neighbours) are sent.
SCHEMA_MAX_TOKENS=6000
# Default table allowlist (empty = all). A connection can override this in its
# options (e.g. {"tables": ["orders", "customers"]}).
SCHEMA_TABLES=
# Default Postgres schemas/namespaces to introspect (comma-separated). A
# connection can override this in its options (e.g. {"schemas": ["public"]}).
SCHEMA_INCLUDE_SCHEMAS=public

# ---------------------------------------------------------------------------
# Connection registry
# Fernet key used to encrypt each data source's password at rest. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Changing this after connections exist makes their stored passwords undecryptable.
# ---------------------------------------------------------------------------
CONNECTIONS_SECRET_KEY=replace-me-with-a-generated-fernet-key

# ---------------------------------------------------------------------------
# Authentication
# Generate a strong secret, e.g.:  openssl rand -hex 32
# ---------------------------------------------------------------------------
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRE_MINUTES=60
# Base URL of the panel, used to build invite acceptance links.
APP_BASE_URL=http://localhost:8000
# Extra browser origins allowed to call the API (comma-separated). Leave empty
# when the SPA is served by the panel itself (the default single-container setup).
CORS_ORIGINS=

# ---------------------------------------------------------------------------
# Query execution guard rails (applied to every AI-generated query)
# QUERY_TIMEOUT_SECONDS is enforced per connection as a best-effort session
# read-only + statement timeout. For strongest safety, point each connection at
# a read-only database user.
# ---------------------------------------------------------------------------
QUERY_MAX_ROWS=1000
QUERY_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Panel database (postgres-panel) — stores users, connections, query history,
# and schema snapshots. This is the ONLY database the panel needs to own.
# ---------------------------------------------------------------------------
PANEL_DB_HOST=postgres-panel
PANEL_DB_PORT=5432
PANEL_DB_NAME=panel
PANEL_DB_USER=panel
PANEL_DB_PASSWORD=replace-me-panel


CREATE USER readonly_user WITH PASSWORD 'PasswordReadOnly123';